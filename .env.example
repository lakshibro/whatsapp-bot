# Environment Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Context Settings (lower = faster responses)
MAX_CONTEXT_MESSAGES=8

# AI Model: gemini-2.0-flash (default) or gemini-2.0-flash-lite (fastest)
# GEMINI_MODEL=gemini-2.0-flash

# Bot Configuration
BOT_NAME=AI Assistant
# Your own WhatsApp ID (country code + number + @c.us) to receive Proactive messages
PRIMARY_USER_WA_ID=94770000000@c.us
